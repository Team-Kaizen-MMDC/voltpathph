# =============================================================================
# Voltpath PH — consolidated environment configuration (monorepo root)
#
# Copy this file to `.env` at the repo ROOT and fill in real values.
# `.env` is gitignored; this template is committed.
#
# How each app reads it (all from this single root file):
#   • API   (apps/api)    — apps/api/src/config.ts loads root .env via dotenv
#   • Web   (apps/web)    — Vite (envDir = repo root); ONLY `VITE_*` vars reach
#                           the browser bundle
#   • Mobile (apps/mobile)— Expo; ONLY `EXPO_PUBLIC_*` vars reach the app
#                           (mobile API wiring is upcoming)
#
# Secrets without a VITE_/EXPO_PUBLIC_ prefix are NOT exposed to the web/mobile
# bundles — only the API process reads them.
# =============================================================================

# ── Shared / runtime ─────────────────────────────────────────────────────────
# "development" | "production" | "test". Production disables schema auto-sync
# (use migrations) and enforces auth.
NODE_ENV=development

# ── API: server ──────────────────────────────────────────────────────────────
# HTTP port the API listens on.
PORT=3001
# Comma-separated browser origins allowed by CORS (e.g. https://app.voltph.com).
# Leave empty in development to reflect the request origin.
WEB_ORIGIN=
# Maximum accepted JSON request body size.
JSON_BODY_LIMIT=1mb

# ── API: database ────────────────────────────────────────────────────────────
# For Supabase / production, set the full connection string below (use the
# SESSION pooler on port 5432 or a direct connection — NOT the transaction
# pooler on 6543, which breaks TypeORM prepared statements). Replace the
# <placeholders> with real values; a value still containing "<" is ignored.
# DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@YOUR_PROJECT.supabase.co:5432/postgres
#
# LOCAL DEV (default): leave DATABASE_URL commented out. The API then uses the
# discrete DB_* vars below, which match docker-compose.yml — run `npm run db:up`
# (auto-detects Docker or Podman) to start a local PostgreSQL + PostGIS container
# with these exact credentials.
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=password
DB_DATABASE=voltph

# ── API: Supabase Auth ───────────────────────────────────────────────────────
SUPABASE_URL=https://<project>.supabase.co
# Server-only privileged key — never expose to clients.
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
# Secret used to VERIFY Supabase JWTs (HS256). If unset in non-production, auth
# is bypassed for local demos; in production a missing value is a hard error.
SUPABASE_JWT_SECRET=your_supabase_jwt_secret

# ── API: Google Maps Platform ────────────────────────────────────────────────
# Key scoped to Directions/Routes, Elevation, and Places. If unset, the API
# falls back to a haversine distance estimate (no live routing/elevation).
GOOGLE_MAPS_API_KEY=your_google_maps_key
# Optional tuning (defaults shown):
GMAPS_DIRECTIONS_TIMEOUT_MS=8000
GMAPS_ELEVATION_TIMEOUT_MS=6000
GMAPS_MAX_ELEVATION_POINTS=350

# ── API: Weather (Open-Meteo — free, no key) ─────────────────────────────────
OPEN_METEO_URL=https://api.open-meteo.com/v1/forecast
WEATHER_TIMEOUT_MS=3000

# ── API: routing fallback tuning (used only by the no-API estimate) ──────────
ROUTE_DETOUR_FACTOR=1.3
FALLBACK_AVG_SPEED_KMH=30

# ── API: charging-station lookups ────────────────────────────────────────────
STATION_SEARCH_RADIUS_M=10000
NEARBY_STATION_LIMIT=5

# ── API: trip logic ──────────────────────────────────────────────────────────
# Arrival State-of-Charge (%) below which charging stops are recommended.
LOW_SOC_THRESHOLD_PERCENT=20

# ── Web (Vite — MUST be prefixed VITE_, inlined into the bundle at build time) ─
VITE_API_URL=http://localhost:3001
# Future, when the web client uses Supabase Auth directly:
# VITE_SUPABASE_URL=https://<project>.supabase.co
# VITE_SUPABASE_ANON_KEY=your_anon_key

# ── Mobile (Expo — MUST be prefixed EXPO_PUBLIC_; wiring upcoming) ────────────
# On a physical device, use your dev machine's LAN IP, not localhost.
EXPO_PUBLIC_API_URL=http://localhost:3001
# EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_key
# EXPO_PUBLIC_SUPABASE_URL=https://<project>.supabase.co
# EXPO_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
