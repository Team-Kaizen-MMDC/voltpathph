# Voltpath PH Web — environment configuration
# Copy this file to `.env` (or `.env.local`). NEVER commit real values.
# Vite only exposes variables prefixed with VITE_, and INLINES them at build
# time — so VITE_API_URL must be set before `npm run build`.

# Base URL of the Voltpath PH API.
VITE_API_URL=http://localhost:3001

# Future — when the web client talks to Supabase Auth directly:
# VITE_SUPABASE_URL=https://<project>.supabase.co
# VITE_SUPABASE_ANON_KEY=your_anon_key
