# Voltpath PH Mobile (Expo) — environment configuration
# Copy this file to `.env`. NEVER commit real values.
# Expo exposes variables prefixed with EXPO_PUBLIC_ to the app at build time.
# (Mobile API wiring is upcoming — these are the variables it will use.)

# Base URL of the Voltpath PH API. On a physical device, use your dev machine's
# LAN IP (e.g. http://192.168.1.10:3001), not localhost.
EXPO_PUBLIC_API_URL=http://localhost:3001

# Future — keys the mobile client may use directly:
# EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_key
# EXPO_PUBLIC_SUPABASE_URL=https://<project>.supabase.co
# EXPO_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
