# ─────────────────────────────────────────────────────────────────────────────
# Voltpath PH API — environment configuration
# Copy this file to `.env` and fill in real values. NEVER commit `.env`.
# Every variable below is read (with safe defaults) in apps/api/src/config.ts.
# ─────────────────────────────────────────────────────────────────────────────

# Node environment: "development" | "production" | "test".
# Production disables schema auto-sync (use migrations) and enforces auth.
NODE_ENV=development

# HTTP port the API listens on.
PORT=3001

# Comma-separated browser origins allowed by CORS (e.g. https://app.voltph.com).
# Leave empty in development to reflect the request origin.
WEB_ORIGIN=

# Maximum accepted JSON request body size.
JSON_BODY_LIMIT=1mb

# ── Database (Supabase Postgres) ─────────────────────────────────────────────
# Preferred: full connection string. Use the Supabase SESSION pooler (port 5432)
# or a direct connection — NOT the transaction pooler (6543), which breaks
# TypeORM prepared statements.
DATABASE_URL=postgresql://postgres:<password>@<project>.supabase.co:5432/postgres

# Discrete fallbacks for local dev (used ONLY when DATABASE_URL is unset):
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=password
DB_DATABASE=voltph

# ── Supabase Auth ────────────────────────────────────────────────────────────
SUPABASE_URL=https://<project>.supabase.co
# Server-only privileged key — never expose to clients.
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
# Secret used to VERIFY Supabase JWTs (HS256). If unset in non-production, auth
# is bypassed for local demos; in production a missing value is a hard error.
SUPABASE_JWT_SECRET=your_supabase_jwt_secret

# ── Google Maps Platform ─────────────────────────────────────────────────────
# Key scoped to Directions/Routes, Elevation, and Places. If unset, the API
# falls back to a haversine distance estimate (no live routing/elevation).
GOOGLE_MAPS_API_KEY=your_google_maps_key
# Optional tuning (defaults shown):
GMAPS_DIRECTIONS_TIMEOUT_MS=8000
GMAPS_ELEVATION_TIMEOUT_MS=6000
GMAPS_MAX_ELEVATION_POINTS=350

# ── Weather (Open-Meteo — free, no key) ──────────────────────────────────────
OPEN_METEO_URL=https://api.open-meteo.com/v1/forecast
WEATHER_TIMEOUT_MS=3000

# ── Routing fallback tuning (used only by the no-API estimate) ───────────────
ROUTE_DETOUR_FACTOR=1.3
FALLBACK_AVG_SPEED_KMH=30

# ── Charging-station lookups ─────────────────────────────────────────────────
STATION_SEARCH_RADIUS_M=10000
NEARBY_STATION_LIMIT=5

# ── Trip logic ───────────────────────────────────────────────────────────────
# Arrival State-of-Charge (%) below which charging stops are recommended.
LOW_SOC_THRESHOLD_PERCENT=20
